var DRIVE_ROOT_FOLDER_URL = "https://drive.google.com/drive/u/0/folders/1GmWU8SfqFVV8zG5PQg7jWf-p0BowPK0L";

var SKIP_SHEETS = [
  "BOOK", "EXPENSES", "EXPENSES DETAIL", "PROFIT AND LOSS",
  "Contrators Total", "Payment Methods", "Payments Made", "Collected Payments"
];

// A   B            C             D              E                   F           G              H              I            J                   K          L
// Mon TENANT NAME  BASE RENT($)  EXTRA CHG($)   EXTRA CHG DESC      LATE FEE($) LATE FEE WAIVE PAYMENT METHOD PAYMENT DATE PAYMENT RECEIVED($) BALANCE($) ON TIME?
var COL_MONTH    = 0;
var COL_TENANT   = 1;
var COL_RENT     = 2;
var COL_EXTRA    = 3;
var COL_LATE_FEE = 5;
var COL_WAIVE    = 6;
var COL_METHOD   = 7;
var COL_DATE     = 8;
var COL_RECEIVED = 9;
var COL_BALANCE  = 10;
var COL_ONTIME   = 11;

var MONTH_ORDER = {
  "January":1,"February":2,"March":3,"April":4,
  "May":5,"June":6,"July":7,"August":8,
  "September":9,"October":10,"November":11,"December":12
};

var TIME_BUFFER_SECS = 60;

