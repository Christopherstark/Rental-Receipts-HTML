// =============================================================
//  BUILD RECEIPT HTML — inline SVG icons, matches v2.html exactly
// =============================================================
function buildReceiptHtml(d, pageOnly) {
  var lc    = d.propertyAddress.lastIndexOf(",");
  var addr1 = lc !== -1 ? d.propertyAddress.substring(0, lc).trim() : d.propertyAddress.trim();
  var addr2 = lc !== -1 ? d.propertyAddress.substring(lc + 1).trim() : "";

  var leasePeriod  = d.rentalMonth + " 1, " + d.rentalYear + " - " + d.rentalMonth + " " + lastDayOfMonth(d.rentalMonth, d.rentalYear) + ", " + d.rentalYear;
  var notes        = d.isLate ? "Late payment recorded for this month." : "Thank you for your on-time payment!";

  // Current balance is calculated from this receipt so overpayments stay negative as credits.
  // Example: rent due $1,915.00 and paid $1,920.00 = -$5.00 credit.
  // This avoids spreadsheet balance formulas that may return a positive absolute value.
  var currentBalance    = roundMoney(d.totalDue - d.amountPaid);
  var hasBalance        = currentBalance > 0;
  var hasCredit         = currentBalance < 0;
  var balanceLabel      = hasBalance ? "REMAINING BALANCE" : (hasCredit ? "CREDIT BALANCE" : "BALANCE DUE");
  var balanceClass      = hasBalance ? "text-red" : "text-green";
  var balanceBox        = hasBalance ? "balance-owed-box" : "balance-ok-box";
  var balanceDisplay    = fmtMoney(currentBalance);
  var nextBalanceLabel  = hasCredit ? "Credit" : "Balance";
  var nextBalanceClass  = hasBalance ? "text-red" : (hasCredit ? "text-green" : "");
