// =============================================================
//  STEP 1: Load months
// =============================================================
function getAvailableMonths() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  var monthSet = {};
  for (var i = 0; i < sheets.length; i++) {
    var name = sheets[i].getName().trim();
    if (SKIP_SHEETS.indexOf(name) !== -1) continue;
    var data = sheets[i].getDataRange().getValues();
    for (var r = 0; r < data.length; r++) {
      var col0 = String(data[r][0] || "").trim();
      var m = col0.match(/^(\d+)\)\s*(\w+)/);
      if (m && MONTH_ORDER[m[2]]) monthSet[m[2]] = true;
    }
  }
  var months = Object.keys(monthSet);
  months.sort(function(a, b) { return MONTH_ORDER[a] - MONTH_ORDER[b]; });
  return months;
}


// =============================================================
//  STEP 2: Load tenants for a month
// =============================================================
function getTenantsForMonth(selectedMonth) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  var tenantSet = {};
  for (var i = 0; i < sheets.length; i++) {
    var name = sheets[i].getName().trim();
    if (SKIP_SHEETS.indexOf(name) !== -1) continue;
    var data = sheets[i].getDataRange().getValues();
    for (var r = 0; r < data.length; r++) {
      var col0   = String(data[r][0] || "").trim();
      var tenant = String(data[r][COL_TENANT] || "").trim();
      var recv   = toNum(data[r][COL_RECEIVED]);
      var m = col0.match(/^(\d+)\)\s*(\w+)/);
      if (!m || m[2] !== selectedMonth) continue;
      if (tenant && recv > 0) tenantSet[tenant] = true;
    }
  }
  var tenants = Object.keys(tenantSet);
  tenants.sort();
  return tenants;
}


// =============================================================
//  QUEUE INIT
// =============================================================
function initQueue(mode, selectedMonth, selectedTenant) {
  var ss        = SpreadsheetApp.getActiveSpreadsheet();
  var sheetYear = new Date().getFullYear();
  var tm = ss.getName().match(/20\d\d/);
  if (tm) sheetYear = parseInt(tm[0]);

  var sheets = ss.getSheets();
  var queue  = [];

  for (var i = 0; i < sheets.length; i++) {
    var sheetName = sheets[i].getName().trim();
    if (SKIP_SHEETS.indexOf(sheetName) !== -1) continue;
    var data    = sheets[i].getDataRange().getValues();
    var address = "";

    for (var r = 0; r < data.length; r++) {
      var row  = data[r];
      var col0 = String(row[0] || "").trim();

      if (String(row[2] || "").trim() === "BASE RENT ($)") {
        address = col0;
        continue;
      }

      var m = col0.match(/^(\d+)\)\s*(\w+)/);
      if (!m || m[2] !== selectedMonth) continue;

      var tenant     = String(row[COL_TENANT]   || "").trim();
      var baseRent   = toNum(row[COL_RENT]);
      var extra      = toNum(row[COL_EXTRA]);
      var lateFeeRaw = toNum(row[COL_LATE_FEE]);
      var isWaived   = String(row[COL_WAIVE] || "").trim().toLowerCase() === "waived";
      var lateFee    = isWaived ? 0 : lateFeeRaw;
      var method     = String(row[COL_METHOD]   || "").trim();
      var payDate    = row[COL_DATE];
      var received   = toNum(row[COL_RECEIVED]);
      var balance    = toNum(row[COL_BALANCE]);
      var onTime     = String(row[COL_ONTIME]   || "").trim();

      if (!tenant || received <= 0) continue;
      if (mode === "single" && tenant !== selectedTenant) continue;

      // Prior balance = balance from the PREVIOUS month's row for this tenant
      // Col K accumulates — so the prior month row shows what they owed before this month
      var currentMonthNum = MONTH_ORDER[selectedMonth];
      var priorBalance = 0;
      if (currentMonthNum > 1) {
        // Look backwards through the sheet for the previous month row for this tenant
        for (var pr = 0; pr < data.length; pr++) {
          var prow = data[pr];
          var pc0  = String(prow[0] || "").trim();
          var pm   = pc0.match(/^(\d+)\)\s*(\w+)/);
          if (!pm) continue;
          var pTenant = String(prow[COL_TENANT] || "").trim();
          if (pm[2] !== selectedMonth && pTenant === tenant) {
            // Find the row with month number = currentMonthNum - 1
            var pMonthNum = MONTH_ORDER[pm[2]];
            if (pMonthNum === currentMonthNum - 1) {
              priorBalance = toNum(prow[COL_BALANCE]);
              break;
            }
          }
        }
      }

      var isLate       = (onTime === "No");
      var totalDue     = baseRent + extra + lateFee + priorBalance;
      var nextMonthIdx = MONTH_ORDER[selectedMonth];
      var nextMonthNum = (nextMonthIdx % 12) + 1;
      var nextYear     = nextMonthNum === 1 ? sheetYear + 1 : sheetYear;
      var nextDueDate  = String(nextMonthNum).padStart(2,"0") + "/01/" + nextYear;
      var lateDueDate  = String(nextMonthNum).padStart(2,"0") + "/05/" + nextYear;
      var nextLateFee  = Math.round(baseRent * 0.10 * 100) / 100;
      var nextMonthKeys = Object.keys(MONTH_ORDER).filter(function(k){ return MONTH_ORDER[k] === nextMonthNum; });
      var nextMonthName = nextMonthKeys.length ? nextMonthKeys[0] : "Next";

      queue.push({
        propertyAddress: address,
        sheetName:       sheetName,
        tenantName:      tenant,
        paymentDate:     fmtDate(payDate),
        rentalMonth:     selectedMonth,
        rentalYear:      sheetYear,
        rentDue:         baseRent,
        extra:           extra,
        lateFee:         lateFee,
        lateFeeRaw:      lateFeeRaw,
        isWaived:        isWaived,
        totalDue:        totalDue,
        amountPaid:      received,
        balance:         balance,
        priorBalance:    priorBalance,
        paymentMethod:   method,
        isLate:          isLate,
        nextDueDate:     nextDueDate,
        lateDueDate:     lateDueDate,
        nextMonthName:   nextMonthName,
        nextRent:        baseRent,
        nextExtra:       extra,
        nextLateFee:     nextLateFee,
        nextTotal:       baseRent + extra
      });
    }
  }

  if (queue.length === 0) {
    return { success: false, message: "No paid rows found for the selected options.", total: 0 };
  }

  PropertiesService.getScriptProperties().setProperty("RECEIPT_QUEUE", JSON.stringify({
    queue: queue, nextIndex: 0, total: queue.length,
    selectedMonth: selectedMonth, sheetYear: sheetYear,
    newCount: 0, skipCount: 0
  }));

  return { success: true, total: queue.length };
}


// =============================================================
//  PROCESS BATCH
// =============================================================
function processBatch() {
  var props = PropertiesService.getScriptProperties();
  var raw   = props.getProperty("RECEIPT_QUEUE");
  if (!raw) return { done: true, message: "No queue found.", newCount: 0, skipCount: 0 };

  var state    = JSON.parse(raw);
  var queue    = state.queue || [];
  var idx      = state.nextIndex || 0;
  var deadline = Date.now() + (360 - TIME_BUFFER_SECS) * 1000;

  var rootId         = extractId(DRIVE_ROOT_FOLDER_URL);
  var rootFolder     = DriveApp.getFolderById(rootId);
  var combinedFolder = getOrCreateFolder(rootFolder, "Receipts " + state.sheetYear);

  while (idx < queue.length && Date.now() < deadline) {
    var item = queue[idx];
    try {
      var tenantFolder = getOrCreateFolder(rootFolder, sanitizeName(item.tenantName));
      var fileName     = sanitizeName(item.tenantName) + "_" + item.rentalMonth + "_" + item.rentalYear;
      // Always replace the monthly receipt PDF if it already exists.
      // This is important after layout or balance fixes; otherwise Apps Script
      // would skip the old PDF and keep showing the previous mistake.
      var existing     = tenantFolder.getFilesByName(fileName + ".pdf");
      while (existing.hasNext()) {
        existing.next().setTrashed(true);
      }

      var htmlContent = buildReceiptHtml(item, false);
      var htmlBlob    = Utilities.newBlob(htmlContent, MimeType.HTML, fileName + ".html");
      var pdfBlob     = htmlBlob.getAs(MimeType.PDF);
      pdfBlob.setName(fileName + ".pdf");
      tenantFolder.createFile(pdfBlob);
      state.newCount++;
    } catch (e) {
      Logger.log("Error for " + item.tenantName + ": " + e.message);
    }
    idx++;
  }

  state.nextIndex = idx;

  if (idx >= queue.length) {
    var combinedMsg = "";
    try {
      var combinedFile = buildCombinedPdf(queue, state.selectedMonth, state.sheetYear, combinedFolder);
      combinedMsg = " Combined PDF saved: " + combinedFile.getName() + ".";
    } catch (e) {
      combinedMsg = " Individual PDFs were processed, but the combined PDF failed: " + e.message;
      Logger.log("Combined PDF error: " + e.message);
    }

    props.deleteProperty("RECEIPT_QUEUE");

    return {
      done: true,
      message: "Done! " + state.newCount + " receipt PDF(s) saved/replaced." + combinedMsg,
      newCount: state.newCount,
      skipCount: state.skipCount
    };
  }

  props.setProperty("RECEIPT_QUEUE", JSON.stringify(state));

  return {
    done: false,
    processed: idx,
    total: queue.length,
    message: "Processing " + idx + " of " + queue.length + "...",
    newCount: state.newCount,
    skipCount: state.skipCount
  };
}


// =============================================================
//  COMBINED PDF
// =============================================================
// The old combined version let the body keep display:flex from the single-receipt
// view. When multiple 8.5in receipts were added side-by-side in one flex row,
// Apps Script's PDF converter could render the first PDF page as blank.
// This version forces block layout and gives each receipt its own letter page.
function buildCombinedPdf(queue, month, year, folder) {
  if (!queue || queue.length === 0) {
    throw new Error("No receipts found to combine.");
  }

  var combinedName = sanitizeName(month + "_" + year + "_All_Receipts") + ".pdf";

  // Remove the previous combined PDF so the folder only keeps the newest one.
  var old = folder.getFilesByName(combinedName);
  while (old.hasNext()) {
    old.next().setTrashed(true);
  }

  var pages = [];
  for (var i = 0; i < queue.length; i++) {
    pages.push(buildReceiptHtml(queue[i], true));
  }

  var combinedPdfCss =
    '<style>' +
      '@page{size:letter;margin:0;}' +
      'html{margin:0!important;padding:0!important;background:#fff!important;}' +
      'body{' +
        'display:block!important;' +
        'justify-content:initial!important;' +
        'align-items:initial!important;' +
        'width:8.5in!important;' +
        'min-width:8.5in!important;' +
        'margin:0!important;' +
        'padding:0!important;' +
        'background:#fff!important;' +
        'overflow:visible!important;' +
      '}' +
      '.receipt-container{' +
        'width:8.5in!important;' +
        'height:11in!important;' +
        'margin:0!important;' +
        'padding:0!important;' +
        'box-shadow:none!important;' +
        'page-break-after:always!important;' +
        'break-after:page!important;' +
        'page-break-inside:avoid!important;' +
        'break-inside:avoid!important;' +
        'overflow:hidden!important;' +
      '}' +
      '.receipt-container:last-child{' +
        'page-break-after:auto!important;' +
        'break-after:auto!important;' +
      '}' +
    '</style>';

  var fullHtml =
    '<!DOCTYPE html>' +
    '<html>' +
      '<head>' +
        '<meta charset="UTF-8">' +
        '<meta name="viewport" content="width=device-width, initial-scale=1.0">' +
        getReceiptCss() +
        combinedPdfCss +
      '</head>' +
      '<body>' +
        pages.join("") +
      '</body>' +
    '</html>';

  var htmlBlob = Utilities.newBlob(
    fullHtml,
    MimeType.HTML,
    combinedName.replace(".pdf", ".html")
  );

  var pdfBlob = htmlBlob.getAs(MimeType.PDF);
  pdfBlob.setName(combinedName);

  var file = folder.createFile(pdfBlob);

  // A very tiny PDF usually means the converter returned an empty/blank result.
  // This gives you a real error instead of a false "saved" message.
  if (file.getSize && file.getSize() < 1000) {
    file.setTrashed(true);
    throw new Error("The combined PDF was created too small, likely blank. Try generating fewer receipts at once.");
  }

  return file;
}



