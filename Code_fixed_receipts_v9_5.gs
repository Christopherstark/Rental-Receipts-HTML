  html += 'select{width:100%;padding:7px;border:1px solid #ccc;border-radius:4px;font-size:13px;margin-bottom:14px;}';
  html += 'button{width:100%;padding:10px;background:#008374;color:white;border:none;border-radius:4px;font-size:14px;font-weight:bold;cursor:pointer;margin-bottom:10px;}';
  html += 'button:hover{background:#006b5e;}button:disabled{background:#aaa;cursor:not-allowed;}';
  html += '.status{padding:10px;border-radius:4px;font-size:12px;display:none;margin-top:8px;white-space:pre-wrap;}';
  html += '.ok{background:#eef7f6;color:#005f52;border:1px solid #008374;}';
  html += '.err{background:#fdecea;color:#a00;border:1px solid #c82333;}';
  html += '.warn{background:#fff8e1;color:#7a5800;border:1px solid #f0c000;}';
  html += '.spinner{display:none;text-align:center;padding:10px;color:#666;}';
  html += '</style></head><body>';
  html += '<h2>&#127968; Generate Receipts</h2>';
  html += '<label for="monthSel">Rental Month</label>';
  html += '<select id="monthSel"><option value="">Loading months...</option></select>';
  html += '<label for="tenantSel">Tenant</label>';
  html += '<select id="tenantSel"><option value="">Select a month first</option></select>';
  html += '<button id="genBtn" onclick="startGenerate()" disabled>Generate Receipts</button>';
  html += '<div class="spinner" id="spinner">Working...</div>';
  html += '<div class="status" id="status"></div>';
  html += '<script>';
  html += 'google.script.run';
  html += '  .withSuccessHandler(function(months){';
  html += '    var sel = document.getElementById("monthSel");';
  html += '    sel.innerHTML = "";';
  html += '    var o = document.createElement("option"); o.value = ""; o.text = "-- Select Month --"; sel.appendChild(o);';
  html += '    months.forEach(function(m){ var op = document.createElement("option"); op.value = m; op.text = m; sel.appendChild(op); });';
  html += '  })';
  html += '  .withFailureHandler(function(e){';
  html += '    var sel = document.getElementById("monthSel"); sel.innerHTML = "";';
  html += '    var o = document.createElement("option"); o.text = "Error: " + e.message; sel.appendChild(o);';
  html += '  })';
  html += '  .getAvailableMonths();';
  html += 'document.getElementById("monthSel").addEventListener("change", function(){';
  html += '  var month = this.value, tSel = document.getElementById("tenantSel"), btn = document.getElementById("genBtn");';
  html += '  btn.disabled = true; tSel.innerHTML = "";';
  html += '  if (!month) { var o = document.createElement("option"); o.text = "Select a month first"; tSel.appendChild(o); return; }';
  html += '  var lo = document.createElement("option"); lo.text = "Loading..."; tSel.appendChild(lo);';
  html += '  google.script.run';
  html += '    .withSuccessHandler(function(tenants){';
  html += '      tSel.innerHTML = "";';
  html += '      var a = document.createElement("option"); a.value = "all"; a.text = "-- All tenants --"; tSel.appendChild(a);';
  html += '      tenants.forEach(function(t){ var op = document.createElement("option"); op.value = t; op.text = t; tSel.appendChild(op); });';
  html += '      btn.disabled = false;';
  html += '    })';
  html += '    .withFailureHandler(function(e){ tSel.innerHTML = ""; var o = document.createElement("option"); o.text = "Error: " + e.message; tSel.appendChild(o); })';
  html += '    .getTenantsForMonth(month);';
  html += '});';
  html += 'function startGenerate() {';
  html += '  var month = document.getElementById("monthSel").value;';
  html += '  var tenant = document.getElementById("tenantSel").value;';
  html += '  if (!month) { alert("Please select a month."); return; }';
  html += '  var mode = (tenant === "all") ? "all" : "single";';
  html += '  document.getElementById("genBtn").disabled = true;';
  html += '  document.getElementById("spinner").style.display = "block";';
  html += '  document.getElementById("status").style.display = "none";';
  html += '  google.script.run';
  html += '    .withSuccessHandler(function(r){';
  html += '      if (!r.success) { setLoading(false); showStatus("Error: " + r.message, "err"); return; }';
  html += '      showStatus("Queue ready: " + r.total + " receipt(s).", "warn");';
  html += '      runBatch();';
  html += '    })';
  html += '    .withFailureHandler(function(e){ setLoading(false); showStatus("Error: " + e.message, "err"); })';
  html += '    .initQueue(mode, month, tenant);';
  html += '}';
  html += 'function runBatch() {';
  html += '  google.script.run';
  html += '    .withSuccessHandler(function(r){';
  html += '      showStatus(r.message, r.done ? "ok" : "warn");';
  html += '      if (!r.done) { setTimeout(runBatch, 1500); } else { setLoading(false); }';
  html += '    })';
  html += '    .withFailureHandler(function(e){ setLoading(false); showStatus("Error: " + e.message, "err"); })';
  html += '    .processBatch();';
  html += '}';
  html += 'function setLoading(on) {';
  html += '  document.getElementById("spinner").style.display = on ? "block" : "none";';
  html += '  document.getElementById("genBtn").disabled = on;';
  html += '}';
  html += 'function showStatus(msg, cls) {';
  html += '  var el = document.getElementById("status");';
  html += '  el.textContent = msg; el.className = "status " + cls; el.style.display = "block";';
  html += '}';
  html += '<\/script></body></html>';
  return html;
}


// =============================================================
//  DIAGNOSE
// =============================================================
function diagnose() {
  var msg = "DIAGNOSE\n";
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    msg += "Spreadsheet: " + ss.getName() + "\n";
    var months = getAvailableMonths();
    msg += "Months: " + months.join(", ") + "\n";
    for (var i = 0; i < months.length; i++) {
      var t = getTenantsForMonth(months[i]);
      msg += "  " + months[i] + " (" + t.length + "): " + t.join(", ") + "\n";
    }
    var rootId = extractId(DRIVE_ROOT_FOLDER_URL);
    msg += "Folder: " + DriveApp.getFolderById(rootId).getName();
  } catch(e) {
    msg += "ERROR: " + e.message;
  }
  Logger.log(msg);
  SpreadsheetApp.getUi().alert(msg);
}


// =============================================================
//  HELPERS
// =============================================================
function extractId(u) {
  if (!u) return "";
  var m = u.match(/\/folders\/([a-zA-Z0-9_-]+)/);
  if (m) return m[1];
  m = u.match(/\/d\/([a-zA-Z0-9_-]+)/);
  if (m) return m[1];
  return u.trim();
}
function getOrCreateFolder(parent, name) {
  var it = parent.getFoldersByName(name);
  return it.hasNext() ? it.next() : parent.createFolder(name);
}
function sanitizeName(s) {
  return s.replace(/[\/\\:*?"<>|]/g, "_").trim();
}
function toNum(val) {
  if (val === null || val === undefined || val === "") return 0;
  var n = parseFloat(String(val).replace(/[$,]/g, ""));
  return isNaN(n) ? 0 : n;
}
function roundMoney(n) {
  return Math.round((toNum(n) + Number.EPSILON) * 100) / 100;
}
function recipientNameStyle(name) {
  // Keep tenant names on one line, but keep the normal 10pt size used by the address block.
  // The wider recipient block prevents normal long names from wrapping.
  // Only extremely long names shrink slightly, then ellipsis is used as a safety fallback.
  var len = String(name || "").length;
  var fontSize = 10;
  if (len > 80) fontSize = 8.4;
  else if (len > 70) fontSize = 8.8;
  else if (len > 60) fontSize = 9.2;
  else if (len > 52) fontSize = 9.6;
  return "display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:" + fontSize + "pt;line-height:1.12;margin:0;padding:0;";
}
function fmtMoney(n) {
  if (!n || n === 0) return "$0.00";
  var s = n < 0 ? "-" : "";
  return s + "$" + Math.abs(n).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
}
function fmtDate(val) {
  if (!val) return "";
  var d = (val instanceof Date) ? val : new Date(val);
  if (isNaN(d)) return String(val);
  return String(d.getMonth()+1).padStart(2,"0") + "/" + String(d.getDate()).padStart(2,"0") + "/" + d.getFullYear();
}
function lastDayOfMonth(monthName, year) {
  var m = MONTH_ORDER[monthName];
  if (!m) return 30;
  return new Date(year, m, 0).getDate();
}
function escHtml(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}
